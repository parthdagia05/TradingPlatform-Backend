# ─────────────────────────────────────────────────────────────────────────────
# NevUp Trade Journal — environment template
#
# Usage:
#   cp .env.example .env       # then edit if needed
#
# This file is COMMITTED. The real .env is git-ignored (see .gitignore).
# In a normal project, the values below would be placeholders like
# "replace-me" or "<your-secret-here>". For this hackathon, the JWT secret is
# published in the kickoff PDF (it's a shared test secret), so we include the
# real value here for reviewer convenience — `docker compose up` must Just Work.
# ─────────────────────────────────────────────────────────────────────────────

# ── HTTP server ───────────────────────────────────────────────────────────────
# Port the API listens on. Docker maps this to the host.
PORT=8080

# ── Postgres ──────────────────────────────────────────────────────────────────
# Connection string format: postgres://USER:PASS@HOST:PORT/DB?sslmode=...
# Host = "localhost" when running `go run` on your machine.
# Host = "postgres"  when running inside docker-compose (service name).
# docker-compose.yml overrides this var so you don't have to think about it.
DATABASE_URL=postgres://nevup:nevup@localhost:5432/nevup?sslmode=disable

# ── Redis (used as our message queue via Streams) ────────────────────────────
# Same host swap as above: localhost vs the "redis" service name in compose.
REDIS_URL=redis://localhost:6379/0

# ── JWT auth ─────────────────────────────────────────────────────────────────
# HS256 shared secret — paste this exact string into all three hackathon tracks.
# Source: NevUp kickoff PDF, section 4 "Authentication".
JWT_SECRET=97791d4db2aa5f689c3cc39356ce35762f0a73aa70923039d8ef72a2840a1b02

# ── Logging ──────────────────────────────────────────────────────────────────
# slog level: debug | info | warn | error
LOG_LEVEL=info

# ── Seed loader ──────────────────────────────────────────────────────────────
# When true, the API loads the CSV into Postgres on first boot (no-op if
# trades already exist). Spec requires this — reviewers must have queryable
# data the moment they run `docker compose up`.
SEED_ON_START=true
SEED_FILE_PATH=./nevup_seed_dataset.csv

# ── Migrations ───────────────────────────────────────────────────────────────
# Path to the .sql files that define the schema. Run on startup.
MIGRATIONS_DIR=./migrations

# ── Redis Streams (the async pipeline) ───────────────────────────────────────
# Stream name = "topic" of trade-close events.
# Group name  = the worker pool that consumes them (lets us scale workers).
# Consumer name = unique identity of THIS worker process within the group.
STREAM_NAME=trade-events
CONSUMER_GROUP=metrics-workers
CONSUMER_NAME=worker-1
