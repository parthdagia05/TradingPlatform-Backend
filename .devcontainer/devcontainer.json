{
  "name": "NevUp Trade Journal",
  "image": "mcr.microsoft.com/devcontainers/go:1.23",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    }
  },
  "forwardPorts": [8080, 5432, 6379],
  "portsAttributes": {
    "8080": { "label": "API" },
    "5432": { "label": "Postgres" },
    "6379": { "label": "Redis" }
  },
  "postCreateCommand": "go mod download",
  "postStartCommand": "echo 'Run: docker compose up --build'"
}
